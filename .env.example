# Copy to .env and adjust values before running locally.
# Never commit .env to version control.

HOST=127.0.0.1
PORT=8003
LOG_LEVEL=INFO

# "file" uses JSONL + CSV; "sqlite" uses a local SQLite database.
STORAGE_BACKEND=file

DATA_DIR=./data_store
CONDITIONS_PATH=./config/conditions.json
WEB_ROOT=./web

RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Validates that a submitted client timestamp is within this many seconds of
# server time. Widen if pilot participants are on unreliable NTP.
TIMESTAMP_TOLERANCE_SECONDS=3600

# Upper bound on reported decision latency. Change for non-standard tasks.
MAX_LATENCY_MS=300000

CORS_ALLOW_ORIGIN=*
